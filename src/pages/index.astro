---
// src/pages/index.astro
// Dashboard de sensores con Astro + Firebase RTDB + Chart.js.
// Todos los estilos usan Tailwind CSS — sin bloque <style> de CSS plano.
// Las vars de entorno PUBLIC_* se inyectan en build y se pasan al
// script del cliente a través de data-attributes.

import '../styles/global.css';

const fbConfig = {
  apiKey:            import.meta.env.PUBLIC_FIREBASE_API_KEY             ?? '',
  authDomain:        import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN         ?? '',
  databaseURL:       import.meta.env.PUBLIC_FIREBASE_DATABASE_URL        ?? '',
  projectId:         import.meta.env.PUBLIC_FIREBASE_PROJECT_ID          ?? '',
  storageBucket:     import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET      ?? '',
  messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID ?? '',
  appId:             import.meta.env.PUBLIC_FIREBASE_APP_ID              ?? '',
};
const sensorsPath = import.meta.env.PUBLIC_SENSORS_PATH ?? 'sensores';
---
<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SensorDB — Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap"
    rel="stylesheet"
  />
</head>

<body class="bg-bg text-[#e2e8f0] font-mono min-h-screen overflow-x-hidden">

  <!-- Config bridge: valores de .env incrustados por Astro en build -->
  <div
    id="__cfg__"
    data-api-key={fbConfig.apiKey}
    data-auth-domain={fbConfig.authDomain}
    data-database-url={fbConfig.databaseURL}
    data-project-id={fbConfig.projectId}
    data-storage-bucket={fbConfig.storageBucket}
    data-messaging-sender-id={fbConfig.messagingSenderId}
    data-app-id={fbConfig.appId}
    data-sensors-path={sensorsPath}
    class="hidden"
  ></div>

  <!-- ─── Header ─────────────────────────────────────────────── -->
  <header class="sticky top-0 z-[100] flex items-center justify-between
                 px-10 py-4 sm:px-5
                 bg-[rgba(7,11,18,0.85)] backdrop-blur-[18px]
                 border-b border-dark">

    <!-- Logo -->
    <div class="font-display text-xl font-extrabold tracking-[-0.02em] flex items-center gap-2.5">
      <span class="w-2.5 h-2.5 bg-accent rounded-full shadow-glow-accent animate-pulse-dot"></span>
      SensorDB
    </div>

    <!-- Connection status -->
    <div class="text-[0.7rem] text-muted text-right leading-[1.8]">
      <div id="connection-badge" class="badge-base badge-disconnected">Desconectado</div>
      <div id="last-update" class="mt-1.5">—</div>
    </div>
  </header>

  <!-- ─── Main ────────────────────────────────────────────────── -->
  <main class="px-10 pt-10 pb-16 max-w-[1600px] mx-auto sm:px-5 sm:pt-6 sm:pb-12">

    <!-- Hero -->
    <div class="mb-12 animate-fade-up">
      <h1 class="font-display font-extrabold tracking-[-0.03em] leading-[1.1] mb-2
                 text-[clamp(2rem,5vw,3.5rem)]
                 bg-gradient-to-br from-[#e2e8f0] to-accent bg-clip-text text-transparent">
        Monitor de Sensores
      </h1>
      <p class="text-[0.8rem] text-muted tracking-[0.08em] uppercase">
        Firebase Realtime Database &middot; Actualización en vivo
      </p>
    </div>

    <!-- Stats bar -->
    <div class="flex gap-4 mb-10 flex-wrap animate-fade-up-delayed">

      <div class="flex flex-col px-[1.4rem] py-[0.9rem]
                  bg-surface border border-dark rounded-xl
                  min-w-[140px] gap-1 transition-colors duration-200
                  hover:border-accent cursor-default">
        <span class="text-[0.65rem] uppercase tracking-[0.1em] text-muted">Sensores activos</span>
        <span id="stat-sensors" class="text-2xl font-display font-bold text-accent">—</span>
      </div>

      <div class="flex flex-col px-[1.4rem] py-[0.9rem]
                  bg-surface border border-dark rounded-xl
                  min-w-[140px] gap-1 transition-colors duration-200
                  hover:border-accent cursor-default">
        <span class="text-[0.65rem] uppercase tracking-[0.1em] text-muted">Total lecturas</span>
        <span id="stat-readings" class="text-2xl font-display font-bold text-accent">—</span>
      </div>

      <div class="flex flex-col px-[1.4rem] py-[0.9rem]
                  bg-surface border border-dark rounded-xl
                  min-w-[140px] gap-1 transition-colors duration-200
                  hover:border-accent cursor-default">
        <span class="text-[0.65rem] uppercase tracking-[0.1em] text-muted">Última lectura</span>
        <span id="stat-last" class="text-base font-display font-bold text-accent">—</span>
      </div>

    </div>

    <!-- Sensors grid -->
    <div
      id="sensors-grid"
      class="grid grid-cols-[repeat(auto-fill,minmax(460px,1fr))] gap-6 sm:grid-cols-1"
    >
      <!-- Loading state (removed once Firebase responds) -->
      <div id="loading-state"
           class="col-span-full flex flex-col items-center justify-center
                  gap-4 py-20 px-8 text-muted text-sm">
        <div class="w-10 h-10 rounded-full border-2 border-dark border-t-accent animate-spin"></div>
        <span>Conectando con Firebase…</span>
      </div>
    </div>

  </main>

  <!-- ─── Client-side script ──────────────────────────────────── -->
  <script type="module">
    import { initializeApp, getApps }
      from 'https://www.gstatic.com/firebasejs/11.0.1/firebase-app.js';
    import { getDatabase, ref, onValue }
      from 'https://www.gstatic.com/firebasejs/11.0.1/firebase-database.js';
    import Chart from 'https://cdn.jsdelivr.net/npm/chart.js@4.4.7/auto/+esm';

    // ── Leer config inyectada por Astro ───────────────────────
    const ds  = document.getElementById('__cfg__').dataset;
    const app = getApps().length ? getApps()[0] : initializeApp({
      apiKey:            ds.apiKey,
      authDomain:        ds.authDomain,
      databaseURL:       ds.databaseUrl,
      projectId:         ds.projectId,
      storageBucket:     ds.storageBucket,
      messagingSenderId: ds.messagingSenderId,
      appId:             ds.appId,
    });
    const db = getDatabase(app);
    const SENSORS_PATH = ds.sensorsPath || 'sensores';

    // ── Paleta de colores por índice de sensor ────────────────
    const PALETTE = [
      '#00e5ff', '#7c3aed', '#f59e0b', '#22c55e',
      '#ec4899', '#f97316', '#06b6d4', '#a855f7',
    ];

    // ── Chart.js defaults ─────────────────────────────────────
    Chart.defaults.color       = '#64748b';
    Chart.defaults.borderColor = '#1b2535';
    Chart.defaults.font.family = '"JetBrains Mono", monospace';
    Chart.defaults.font.size   = 11;

    const instances    = {};
    let   totalReadings = 0;

    // ── Helpers de tiempo ─────────────────────────────────────
    function toMs(raw) {
      if (!raw) return Date.now();
      const n = Number(raw);
      if (!isNaN(n)) return n > 1e12 ? n : n * 1000;
      const p = Date.parse(raw);
      return isNaN(p) ? Date.now() : p;
    }
    const fmtTime = r => new Date(toMs(r)).toLocaleTimeString('es-CO',
      { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
    const fmtFull = r => new Date(toMs(r)).toLocaleString('es-CO', { hour12: false });

    /**
     * Normaliza cualquier forma de datos a [{ts, valor, unidad}].
     * Soporta: Object key→{valor,timestamp,...} | Array | key→primitivo | escalar
     */
    function normalize(raw) {
      if (raw == null) return [];
      if (typeof raw !== 'object')
        return [{ ts: Date.now(), valor: +raw, unidad: '' }];
      if (Array.isArray(raw))
        return raw.filter(Boolean).map((x, i) => ({
          ts:     x.timestamp ?? x.ts ?? x.time ?? i,
          valor:  +(x.valor ?? x.value ?? x.data ?? x.reading ?? 0),
          unidad: x.unidad ?? x.unit ?? '',
        }));
      const keys = Object.keys(raw);
      if (keys.length <= 2 && ('valor' in raw || 'value' in raw))
        return [{ ts: raw.timestamp ?? raw.ts ?? Date.now(),
                  valor: +(raw.valor ?? raw.value ?? 0),
                  unidad: raw.unidad ?? raw.unit ?? '' }];
      if (keys.every(k => typeof raw[k] !== 'object' || raw[k] === null))
        return keys.map(k => ({ ts: k, valor: +raw[k], unidad: '' }));
      return keys.map(k => {
        const x = raw[k];
        if (typeof x !== 'object') return { ts: k, valor: +x, unidad: '' };
        return {
          ts:     x.timestamp ?? x.ts ?? x.time ?? k,
          valor:  +(x.valor ?? x.value ?? x.data ?? x.reading
                  ?? Object.values(x).find(v => typeof v === 'number') ?? 0),
          unidad: x.unidad ?? x.unit ?? x.tipo ?? '',
        };
      });
    }

    /** Separa el nodo de datos de los metadatos del sensor */
    function splitObj(obj) {
      if (!obj || typeof obj !== 'object') return { dataNode: obj, meta: {} };
      const DATA = new Set(['datos', 'data', 'lecturas', 'readings', 'values', 'history']);
      const meta = {};
      let   dataNode = null;
      for (const [k, v] of Object.entries(obj)) {
        if (DATA.has(k)) dataNode = v;
        else if (typeof v !== 'object') meta[k] = v;
      }
      return { dataNode: dataNode ?? obj, meta };
    }

    /** Genera filas HTML para la tabla de lecturas */
    const buildRows = rows =>
      [...rows].reverse().slice(0, 30).map(r => `
        <tr>
          <td>${fmtFull(r.ts)}</td>
          <td style="font-weight:500;color:#e2e8f0">${r.valor}</td>
          <td>${r.unidad || '—'}</td>
        </tr>`).join('');

    /** Crea o actualiza una tarjeta de sensor */
    function upsertCard(id, sensorData, idx) {
      const color = PALETTE[idx % PALETTE.length];
      const { dataNode, meta } = splitObj(sensorData);
      const allRows = normalize(dataNode).sort((a, b) => toMs(a.ts) - toMs(b.ts));
      const rows    = allRows.slice(-50);

      // Actualizar tarjeta existente
      if (instances[id]) {
        const { chart, tbodyEl } = instances[id];
        chart.data.labels           = rows.map(r => fmtTime(r.ts));
        chart.data.datasets[0].data = rows.map(r => r.valor);
        chart.update('active');
        tbodyEl.innerHTML = buildRows(rows);
        const el = document.getElementById(`latest-${id}`);
        if (el) el.textContent = rows.at(-1)?.valor ?? '—';
        document.getElementById('stat-last').textContent = fmtTime(rows.at(-1)?.ts);
        return;
      }

      // Crear nueva tarjeta
      const grid = document.getElementById('sensors-grid');
      const unit = rows.find(r => r.unidad)?.unidad ?? '';
      const metaHtml = Object.entries(meta)
        .map(([k, v]) => `<span class="meta-tag">${k}: ${v}</span>`).join('')
        || '<span class="meta-tag">sin metadatos</span>';

      const card = document.createElement('div');
      card.className = 'sensor-card';
      card.id        = `card-${id}`;
      card.style.setProperty('--card-color', color);
      card.style.animationDelay = `${idx * 0.07}s`;

      card.innerHTML = `
        <div class="card-header">
          <div>
            <div class="sensor-id">${id.replace(/_/g, ' ')}</div>
            <div class="sensor-meta">${metaHtml}</div>
          </div>
          <div class="latest-value">
            <span class="num" id="latest-${id}">${rows.at(-1)?.valor ?? '—'}</span>
            <span class="unit" id="unit-${id}">${unit}</span>
          </div>
        </div>
        <div class="chart-wrapper">
          <canvas id="chart-${id}"></canvas>
        </div>
        <div class="data-table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Timestamp</th>
                <th>Valor</th>
                <th>Unidad</th>
              </tr>
            </thead>
            <tbody id="tbody-${id}">${buildRows(rows)}</tbody>
          </table>
        </div>`;

      grid.appendChild(card);

      // Chart.js
      const chart = new Chart(document.getElementById(`chart-${id}`), {
        type: 'line',
        data: {
          labels:   rows.map(r => fmtTime(r.ts)),
          datasets: [{
            label:               id,
            data:                rows.map(r => r.valor),
            borderColor:         color,
            backgroundColor:     color + '18',
            borderWidth:         2,
            pointRadius:         rows.length > 20 ? 0 : 3,
            pointHoverRadius:    5,
            pointBackgroundColor: color,
            fill:    true,
            tension: 0.4,
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          animation:   { duration: 400 },
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#0d1420',
              borderColor: color, borderWidth: 1,
              titleColor: color, bodyColor: '#e2e8f0', padding: 10,
              callbacks: { label: c => ` ${c.parsed.y}${unit ? ' ' + unit : ''}` },
            },
          },
          scales: {
            x: { grid: { color: '#1b2535' }, ticks: { maxRotation: 0, maxTicksLimit: 6 } },
            y: { grid: { color: '#1b2535' }, ticks: { callback: v => unit ? `${v} ${unit}` : v } },
          },
        },
      });

      instances[id] = { chart, tbodyEl: document.getElementById(`tbody-${id}`) };
      totalReadings += allRows.length;
      document.getElementById('stat-readings').textContent =
        totalReadings.toLocaleString('es-CO');
      document.getElementById('stat-last').textContent =
        fmtTime(rows.at(-1)?.ts);
    }

    // ── Listener principal en Firebase ─────────────────────────
    onValue(
      ref(db, SENSORS_PATH),
      snap => {
        // Quitar spinner
        document.getElementById('loading-state')?.remove();

        // Badge → conectado
        const badge = document.getElementById('connection-badge');
        badge.textContent = 'Conectado';
        badge.classList.remove('badge-disconnected');
        badge.classList.add('badge-connected');

        document.getElementById('last-update').textContent =
          new Date().toLocaleTimeString('es-CO', { hour12: false });

        const data = snap.val();
        if (!data) {
          document.getElementById('sensors-grid').innerHTML =
            `<div id="error-state">
              <strong>Sin datos</strong>
              <span>No se encontraron entradas en <code>${SENSORS_PATH}</code></span>
            </div>`;
          return;
        }

        totalReadings = 0;
        const ids = Object.keys(data);
        document.getElementById('stat-sensors').textContent = ids.length;
        ids.forEach((id, i) => upsertCard(id, data[id], i));
      },
      err => {
        console.error('[SensorDB]', err);
        document.getElementById('sensors-grid').innerHTML =
          `<div id="error-state">
            <strong>Error de conexión</strong>
            <span>${err.message}</span>
            <small style="margin-top:.5rem;font-size:.7rem">
              Verifica tu .env y las reglas de seguridad en Firebase Console
            </small>
          </div>`;
      }
    );
  </script>

</body>
</html>
